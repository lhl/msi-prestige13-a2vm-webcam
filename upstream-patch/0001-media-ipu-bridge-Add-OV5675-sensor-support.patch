From ed87a09ecbfacba4d0808738d6600e9e4b26910a Mon Sep 17 00:00:00 2001
From: lhl <lhl@randomfoo.net>
Date: Thu, 12 Mar 2026 05:34:22 +0900
Subject: [PATCH 1/6] media: ipu-bridge: Add OV5675 sensor support

Add the Omnivision OV5675 (ACPI HID OVTI5675) to the list of sensors
known to ipu-bridge, so that the bridge creates the required V4L2
fwnode endpoint when the sensor is present.

Tested on the MSI Prestige 13 AI+ Evo A2VMG (Lunar Lake / IPU7), where
this is the built-in webcam sensor.

Signed-off-by: lhl <lhl@randomfoo.net>
---
 drivers/media/pci/intel/ipu-bridge.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/drivers/media/pci/intel/ipu-bridge.c b/drivers/media/pci/intel/ipu-bridge.c
index 32cc95a766b7..e2bf1b6b354d 100644
--- a/drivers/media/pci/intel/ipu-bridge.c
+++ b/drivers/media/pci/intel/ipu-bridge.c
@@ -91,6 +91,8 @@ static const struct ipu_sensor_config ipu_supported_sensors[] = {
 	IPU_SENSOR_CONFIG("OVTIDB10", 1, 560000000),
 	/* Omnivision OV2680 */
 	IPU_SENSOR_CONFIG("OVTI2680", 1, 331200000),
+	/* Omnivision OV5675 */
+	IPU_SENSOR_CONFIG("OVTI5675", 1, 450000000),
 	/* Omnivision OV8856 */
 	IPU_SENSOR_CONFIG("OVTI8856", 3, 180000000, 360000000, 720000000),
 	/* Sony IMX471 */
