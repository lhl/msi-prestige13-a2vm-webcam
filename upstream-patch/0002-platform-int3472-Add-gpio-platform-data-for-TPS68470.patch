From: FIXME <FIXME>
Subject: [PATCH 2/5] platform: int3472: Add gpio platform data for TPS68470

The TPS68470 PMIC supports an I2C daisy-chain mode that uses GPIO lines
1 and 2.  Some boards require this mode to be enabled at probe time
before the sensor driver requests those lines.

Add a tps68470_gpio_platform_data structure with a daisy_chain_enable
flag, plumb it from the int3472 board-data table through to the
tps68470-gpio MFD cell, so that the GPIO driver can act on it during
probe.

Signed-off-by: FIXME <FIXME>
---
 include/linux/platform_data/tps68470.h              | 6 ++++++
 drivers/platform/x86/intel/int3472/tps68470.h       | 2 ++
 drivers/platform/x86/intel/int3472/tps68470.c       | 4 ++++
 3 files changed, 12 insertions(+)

--- a/include/linux/platform_data/tps68470.h
+++ b/include/linux/platform_data/tps68470.h
@@ -10,6 +10,8 @@
 #ifndef __PDATA_TPS68470_H
 #define __PDATA_TPS68470_H

+#include <linux/types.h>
+
 enum tps68470_regulators {
 	TPS68470_CORE,
 	TPS68470_ANA,
@@ -27,6 +29,10 @@ struct tps68470_regulator_platform_data {
 	const struct regulator_init_data *reg_init_data[TPS68470_NUM_REGULATORS];
 };

+struct tps68470_gpio_platform_data {
+	bool daisy_chain_enable;
+};
+
 struct tps68470_clk_consumer {
 	const char *consumer_dev_name;
 	const char *consumer_con_id;
--- a/drivers/platform/x86/intel/int3472/tps68470.h
+++ b/drivers/platform/x86/intel/int3472/tps68470.h
@@ -12,11 +12,13 @@
 #define _INTEL_SKL_INT3472_TPS68470_H

 struct gpiod_lookup_table;
+struct tps68470_gpio_platform_data;
 struct tps68470_regulator_platform_data;

 struct int3472_tps68470_board_data {
 	const char *dev_name;
 	const struct tps68470_regulator_platform_data *tps68470_regulator_pdata;
+	const struct tps68470_gpio_platform_data *tps68470_gpio_pdata;
 	unsigned int n_gpiod_lookups;
 	struct gpiod_lookup_table *tps68470_gpio_lookup_tables[];
 };
--- a/drivers/platform/x86/intel/int3472/tps68470.c
+++ b/drivers/platform/x86/intel/int3472/tps68470.c
@@ -197,6 +197,10 @@ static int skl_int3472_tps68470_probe(struct i2c_client *client)
 		cells[1].platform_data = (void *)board_data->tps68470_regulator_pdata;
 		cells[1].pdata_size = sizeof(struct tps68470_regulator_platform_data);
 		cells[2].name = "tps68470-gpio";
+		if (board_data->tps68470_gpio_pdata) {
+			cells[2].platform_data = (void *)board_data->tps68470_gpio_pdata;
+			cells[2].pdata_size = sizeof(*board_data->tps68470_gpio_pdata);
+		}

 		for (i = 0; i < board_data->n_gpiod_lookups; i++)
 			gpiod_add_lookup_table(board_data->tps68470_gpio_lookup_tables[i]);
