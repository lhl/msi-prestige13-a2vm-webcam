From b47c6e44ba31595b22b5585f5dcbf7af48fdc970 Mon Sep 17 00:00:00 2001
From: lhl <lhl@randomfoo.net>
Date: Thu, 12 Mar 2026 05:34:28 +0900
Subject: [PATCH 2/6] platform: int3472: Pass daisy-chain-enable property to
 TPS68470 GPIO

Some boards need the TPS68470 GPIO cell to configure its I2C
daisy-chain lines before the sensor driver probes.

Describe that requirement with a software-node property attached to
the tps68470-gpio MFD cell, so the board-data table can request the
behavior without introducing new public TPS68470 platform data.

Signed-off-by: lhl <lhl@randomfoo.net>
---
 drivers/platform/x86/intel/int3472/tps68470.c | 12 ++++++++++++
 drivers/platform/x86/intel/int3472/tps68470.h |  3 +++
 2 files changed, 15 insertions(+)

diff --git a/drivers/platform/x86/intel/int3472/tps68470.c b/drivers/platform/x86/intel/int3472/tps68470.c
index a496075c0d2a..075d669dcf4f 100644
--- a/drivers/platform/x86/intel/int3472/tps68470.c
+++ b/drivers/platform/x86/intel/int3472/tps68470.c
@@ -8,6 +8,7 @@
 #include <linux/mfd/tps68470.h>
 #include <linux/platform_device.h>
 #include <linux/platform_data/tps68470.h>
+#include <linux/property.h>
 #include <linux/platform_data/x86/int3472.h>
 #include <linux/regmap.h>
 #include <linux/string.h>
@@ -30,6 +31,15 @@ static const struct regmap_config tps68470_regmap_config = {
 	.max_register = TPS68470_REG_MAX,
 };
 
+static const struct property_entry tps68470_gpio_props[] = {
+	PROPERTY_ENTRY_BOOL("daisy-chain-enable"),
+	{ }
+};
+
+static const struct software_node tps68470_gpio_swnode = {
+	.properties = tps68470_gpio_props,
+};
+
 static int tps68470_chip_init(struct device *dev, struct regmap *regmap)
 {
 	unsigned int version;
@@ -197,6 +207,8 @@ static int skl_int3472_tps68470_probe(struct i2c_client *client)
 		cells[1].platform_data = (void *)board_data->tps68470_regulator_pdata;
 		cells[1].pdata_size = sizeof(struct tps68470_regulator_platform_data);
 		cells[2].name = "tps68470-gpio";
+		if (board_data->tps68470_gpio_daisy_chain)
+			cells[2].swnode = &tps68470_gpio_swnode;
 
 		for (i = 0; i < board_data->n_gpiod_lookups; i++)
 			gpiod_add_lookup_table(board_data->tps68470_gpio_lookup_tables[i]);
diff --git a/drivers/platform/x86/intel/int3472/tps68470.h b/drivers/platform/x86/intel/int3472/tps68470.h
index 35915e701593..dc8fd2a9b8b0 100644
--- a/drivers/platform/x86/intel/int3472/tps68470.h
+++ b/drivers/platform/x86/intel/int3472/tps68470.h
@@ -11,12 +11,15 @@
 #ifndef _INTEL_SKL_INT3472_TPS68470_H
 #define _INTEL_SKL_INT3472_TPS68470_H
 
+#include <linux/types.h>
+
 struct gpiod_lookup_table;
 struct tps68470_regulator_platform_data;
 
 struct int3472_tps68470_board_data {
 	const char *dev_name;
 	const struct tps68470_regulator_platform_data *tps68470_regulator_pdata;
+	bool tps68470_gpio_daisy_chain;
 	unsigned int n_gpiod_lookups;
 	struct gpiod_lookup_table *tps68470_gpio_lookup_tables[];
 };
