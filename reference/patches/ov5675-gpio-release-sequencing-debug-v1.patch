+static void ov5675_release_power_gpios(struct ov5675 *ov5675)
+{
+	if (ov5675_gpio_release_sequence || ov5675_gpio_release_delay_us)
+		dev_info(ov5675->dev,
+			 "applying gpio release sequence=%u delay_us=%u\n",
+			 ov5675_gpio_release_sequence,
+			 ov5675_gpio_release_delay_us);
+
+	switch (ov5675_gpio_release_sequence) {
+	case 1:
+		gpiod_set_value_cansleep(ov5675->powerdown_gpio, 0);
+		if (ov5675_gpio_release_delay_us)
+			usleep_range(ov5675_gpio_release_delay_us,
+				     ov5675_gpio_release_delay_us + 100);
+		gpiod_set_value_cansleep(ov5675->reset_gpio, 0);
+		break;
+	case 2:
+		gpiod_set_value_cansleep(ov5675->reset_gpio, 0);
+		if (ov5675_gpio_release_delay_us)
+			usleep_range(ov5675_gpio_release_delay_us,
+				     ov5675_gpio_release_delay_us + 100);
+		gpiod_set_value_cansleep(ov5675->powerdown_gpio, 0);
+		break;
+	default:
+		gpiod_set_value_cansleep(ov5675->powerdown_gpio, 0);
+		gpiod_set_value_cansleep(ov5675->reset_gpio, 0);
+		break;
+	}
+}
