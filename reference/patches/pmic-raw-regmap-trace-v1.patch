+	dev_info(clkdata->dev,
+		 "pmic_raw: %s write reg=%s(0x%02x) value=0x%02x before_ret=%d before=0x%02x write_ret=%d after_ret=%d after=0x%02x\n",
+		 tag, tps68470_clk_reg_name(reg), reg, value,
+		 before_ret, before, ret, after_ret, after);
+
+	return ret;
+}
