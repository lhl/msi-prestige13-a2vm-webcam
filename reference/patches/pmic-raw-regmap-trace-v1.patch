+static const char *tps68470_regulator_reg_name(unsigned int reg)
+{
+	switch (reg) {
+	case TPS68470_REG_VCMVAL:
+		return "VCMVAL";
+	case TPS68470_REG_VIOVAL:
+		return "VIOVAL";
+	case TPS68470_REG_VSIOVAL:
+		return "VSIOVAL";
+	case TPS68470_REG_VAVAL:
+		return "VAVAL";
+	case TPS68470_REG_VDVAL:
+		return "VDVAL";
+	case TPS68470_REG_S_I2C_CTL:
+		return "S_I2C_CTL";
+	case TPS68470_REG_VCMCTL:
+		return "VCMCTL";
+	case TPS68470_REG_VACTL:
+		return "VACTL";
+	case TPS68470_REG_VDCTL:
+		return "VDCTL";
+	default:
+		return "UNKNOWN";
+	}
+}
+
+static bool tps68470_regulator_trace_snapshot_needed(struct regulator_dev *rdev)
+{
+	switch (rdev->desc->id) {
+	case TPS68470_CORE:
+	case TPS68470_ANA:
+	case TPS68470_VCM:
+	case TPS68470_VIO:
+	case TPS68470_VSIO:
+		return true;
+	default:
+		return false;
+	}
+}
+
+static void tps68470_regulator_log_read(struct regulator_dev *rdev,
+					const char *tag, unsigned int reg)
+{
+	unsigned int val = 0;
+	int ret;
+
+	ret = regmap_read(rdev->regmap, reg, &val);
+	dev_info(&rdev->dev,
+		 "pmic_raw: %s %s read reg=%s(0x%02x) ret=%d val=0x%02x\n",
+		 tag, rdev->desc->name,
+		 tps68470_regulator_reg_name(reg), reg, ret, val);
+}
+
+static void tps68470_regulator_log_snapshot(struct regulator_dev *rdev,
+					    const char *tag)
+{
+	static const unsigned int regs[] = {
+		TPS68470_REG_VCMVAL,
+		TPS68470_REG_VIOVAL,
+		TPS68470_REG_VSIOVAL,
+		TPS68470_REG_VAVAL,
+		TPS68470_REG_VDVAL,
+		TPS68470_REG_S_I2C_CTL,
+		TPS68470_REG_VCMCTL,
+		TPS68470_REG_VACTL,
+		TPS68470_REG_VDCTL,
+	};
+	int i;
+
+	if (!tps68470_regulator_trace_snapshot_needed(rdev))
+		return;
+
+	for (i = 0; i < ARRAY_SIZE(regs); i++)
+		tps68470_regulator_log_read(rdev, tag, regs[i]);
+}
+
+static int tps68470_regulator_update_bits_trace(struct regulator_dev *rdev,
+						unsigned int reg,
+						unsigned int mask,
+						unsigned int value,
+						const char *tag)
+{
+	unsigned int before = 0;
+	unsigned int after = 0;
+	int before_ret;
+	int ret;
+	int after_ret;
+
+	before_ret = regmap_read(rdev->regmap, reg, &before);
+	ret = regmap_update_bits(rdev->regmap, reg, mask, value);
+	after_ret = regmap_read(rdev->regmap, reg, &after);
+
+	dev_info(&rdev->dev,
+		 "pmic_raw: %s %s update reg=%s(0x%02x) mask=0x%02x value=0x%02x before_ret=%d before=0x%02x update_ret=%d after_ret=%d after=0x%02x\n",
+		 tag, rdev->desc->name,
+		 tps68470_regulator_reg_name(reg), reg, mask, value,
+		 before_ret, before, ret, after_ret, after);
+
+	return ret;
+}
+
+static int tps68470_regulator_set_voltage_sel(struct regulator_dev *rdev,
+					      unsigned int sel)
+{
+	unsigned int value;
+	int ret;
+
+	tps68470_regulator_log_snapshot(rdev, "set_voltage_sel(pre)");
+
+	value = sel << (ffs(rdev->desc->vsel_mask) - 1);
+	ret = tps68470_regulator_update_bits_trace(rdev, rdev->desc->vsel_reg,
+						   rdev->desc->vsel_mask,
+						   value, "set_voltage_sel");
+	if (ret)
+		return ret;
+
+	if (rdev->desc->apply_bit) {
+		ret = tps68470_regulator_update_bits_trace(rdev,
+							   rdev->desc->apply_reg,
+							   rdev->desc->apply_bit,
+							   rdev->desc->apply_bit,
+							   "apply_voltage_sel");
+		if (ret)
+			return ret;
+	}
+
+	tps68470_regulator_log_snapshot(rdev, "set_voltage_sel(post)");
+
+	return 0;
+}
