+static unsigned int tps68470_core_mv_to_sel(unsigned int mv)
+{
+	unsigned int uv = mv * 1000;
+	unsigned int sel;
+
+	if (uv <= 900000)
+		return 0;
+
+	sel = DIV_ROUND_UP(uv - 900000, 25000);
+	return min(sel, (unsigned int)TPS68470_VDVAL_DVOLT_MASK);
+}
+
+static unsigned int tps68470_ldo_mv_to_sel(unsigned int mv)
+{
+	unsigned int uv = mv * 1000;
+	unsigned int sel;
+
+	if (uv <= 875000)
+		return 0;
+
+	sel = DIV_ROUND_UP(uv - 875000, 17800);
+	return min(sel, (unsigned int)TPS68470_VAVAL_AVOLT_MASK);
+}
+
+static int tps68470_apply_wf_init_data(struct regulator_dev *rdev)
+{
+	struct tps68470_regulator_data *data = rdev->reg_data;
+	const struct tps68470_regulator_wf_init_data *wf = data->wf_init_data;
+
+	dev_info(&rdev->dev,
+		 "applying WF init value programming: VD=%umV VA=%umV VCM=%umV VIO=%umV VSIO=%umV\n",
+		 wf->core_mv, wf->ana_mv, wf->vcm_mv, wf->vio_mv, wf->vsio_mv);
+
+	regmap_write(data->regmap, TPS68470_REG_VAVAL,
+		     tps68470_ldo_mv_to_sel(wf->ana_mv));
+	regmap_write(data->regmap, TPS68470_REG_VSIOVAL,
+		     tps68470_ldo_mv_to_sel(wf->vsio_mv));
+	regmap_write(data->regmap, TPS68470_REG_VDVAL,
+		     tps68470_core_mv_to_sel(wf->core_mv));
+	regmap_write(data->regmap, TPS68470_REG_VCMVAL,
+		     tps68470_ldo_mv_to_sel(wf->vcm_mv));
+	regmap_write(data->regmap, TPS68470_REG_VIOVAL,
+		     tps68470_ldo_mv_to_sel(wf->vio_mv));
+
+	return 0;
+}
