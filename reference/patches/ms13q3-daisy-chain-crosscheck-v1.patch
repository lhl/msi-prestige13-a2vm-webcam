+static int tps68470_enable_i2c_daisy_chain(struct tps68470_gpio_data *tps68470_gpio)
+{
+	struct gpio_chip *gc = &tps68470_gpio->gc;
+	int ret;
+
+	dev_info(gc->parent,
+		 "exp12_daisy: enabling Antti-inspired daisy-chain cross-check on gpio.1/gpio.2\n");
+	tps68470_gpio_log_daisy_state(tps68470_gpio, 1, "probe-before");
+	tps68470_gpio_log_daisy_state(tps68470_gpio, 2, "probe-before");
+
+	ret = tps68470_gpio_input(gc, 1);
+	if (ret)
+		return ret;
+
+	ret = tps68470_gpio_input(gc, 2);
+	if (ret)
+		return ret;
+
+	tps68470_gpio_log_daisy_state(tps68470_gpio, 1, "probe-after");
+	tps68470_gpio_log_daisy_state(tps68470_gpio, 2, "probe-after");
+
+	return 0;
+}
