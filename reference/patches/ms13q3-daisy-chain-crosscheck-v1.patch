+static bool tps68470_gpio_is_daisy_chain_line(unsigned int offset)
+{
+	return offset == 1 || offset == 2;
+}
+
+static void tps68470_gpio_log_daisy_state(struct tps68470_gpio_data *tps68470_gpio,
+					  unsigned int offset,
+					  const char *tag)
+{
+	struct regmap *regmap = tps68470_gpio->tps68470_regmap;
+	unsigned int ctl = 0, gpdo = 0;
+	int ctl_ret, gpdo_ret;
+
+	if (!tps68470_gpio->daisy_chain_enabled ||
+	    !tps68470_gpio_is_daisy_chain_line(offset))
+		return;
+
+	ctl_ret = regmap_read(regmap, TPS68470_GPIO_CTL_REG_A(offset), &ctl);
+	gpdo_ret = regmap_read(regmap, TPS68470_REG_GPDO, &gpdo);
+
+	dev_info(tps68470_gpio->gc.parent,
+		 "exp12_daisy: %s gpio.%u ctl_ret=%d ctl=0x%02x gpdo_ret=%d gpdo=0x%02x\n",
+		 tag, offset, ctl_ret, ctl, gpdo_ret, gpdo);
+}
