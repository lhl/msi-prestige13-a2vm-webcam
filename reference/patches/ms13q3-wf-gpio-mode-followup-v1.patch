+#include <linux/delay.h>
 #include <linux/gpio/driver.h>
 #include <linux/mfd/tps68470.h>
 #include <linux/module.h>
@@ -86,6 +87,36 @@
 				  value ? BIT(offset) : 0);
 }
 
+static int tps68470_gpio_prepare_wf_mode(struct gpio_chip *gc,
+					 unsigned int offset)
+{
+	struct tps68470_gpio_data *tps68470_gpio = gpiochip_get_data(gc);
+	struct regmap *regmap = tps68470_gpio->tps68470_regmap;
+	unsigned int reg = TPS68470_GPIO_CTL_REG_A(offset);
+	int val;
+	int ret;
+
+	if (offset != 1 && offset != 2)
+		return 0;
+
+	ret = regmap_update_bits(regmap, reg, TPS68470_GPIO_MODE_MASK,
+				 TPS68470_GPIO_MODE_IN);
+	if (ret)
+		return ret;
+
+	usleep_range(1000, 1500);
+
+	ret = regmap_read(regmap, reg, &val);
+	if (ret)
+		return ret;
+
+	dev_info(tps68470_gpio->gc.parent,
+		 "WF GPIO mode follow-up: gpio.%u GPCTL%uA pre-clear=0x%02x\n",
+		 offset, offset, val);
+
+	return 0;
+}
+
 static int tps68470_gpio_output(struct gpio_chip *gc, unsigned int offset,
 				int value)
 {
@@ -93,6 +124,10 @@
 	struct regmap *regmap = tps68470_gpio->tps68470_regmap;
 	int ret;
 
+	ret = tps68470_gpio_prepare_wf_mode(gc, offset);
+	if (ret)
+		return ret;
+
 	/* Set the initial value */
 	ret = tps68470_gpio_set(gc, offset, value);
 	if (ret)
@@ -102,9 +137,22 @@
 	if (offset >= TPS68470_N_REGULAR_GPIO)
 		return 0;
 
-	return regmap_update_bits(regmap, TPS68470_GPIO_CTL_REG_A(offset),
+	ret = regmap_update_bits(regmap, TPS68470_GPIO_CTL_REG_A(offset),
 				 TPS68470_GPIO_MODE_MASK,
 				 TPS68470_GPIO_MODE_OUT_CMOS);
+	if (ret)
+		return ret;
+
+	if (offset == 1 || offset == 2) {
+		int val;
+
+		if (!regmap_read(regmap, TPS68470_GPIO_CTL_REG_A(offset), &val))
+			dev_info(tps68470_gpio->gc.parent,
+				 "WF GPIO mode follow-up: gpio.%u GPCTL%uA output=0x%02x\n",
+				 offset, offset, val);
+	}
+
+	return 0;
 }
 
