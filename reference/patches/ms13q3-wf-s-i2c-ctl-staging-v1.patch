+static int tps68470_regulator_enable_vsio_staged(struct regulator_dev *rdev)
+{
+	struct tps68470_regulator_data *data = rdev->reg_data;
+	unsigned int val = 0;
+	int ret;
+
+	regmap_read(data->regmap, TPS68470_REG_S_I2C_CTL, &val);
+	dev_info(&rdev->dev, "WF S_I2C_CTL staged enable start old=0x%02x\n", val);
+
+	ret = regmap_update_bits(data->regmap, TPS68470_REG_S_I2C_CTL, BIT(1), BIT(1));
+	if (ret)
+		return ret;
+
+	usleep_range(1000, 1500);
+
+	ret = regmap_update_bits(data->regmap, TPS68470_REG_S_I2C_CTL, BIT(0), BIT(0));
+	if (ret)
+		return ret;
+
+	regmap_read(data->regmap, TPS68470_REG_S_I2C_CTL, &val);
+	dev_info(&rdev->dev, "WF S_I2C_CTL staged enable done S_I2C_CTL=0x%02x\n",
+		 val);
+
+	return 0;
+}
+
+static int tps68470_regulator_disable_vsio_staged(struct regulator_dev *rdev)
+{
+	struct tps68470_regulator_data *data = rdev->reg_data;
+	unsigned int val = 0;
+	int ret;
+
+	ret = regmap_update_bits(data->regmap, TPS68470_REG_S_I2C_CTL,
+				 GENMASK(1, 0), 0);
+	regmap_read(data->regmap, TPS68470_REG_S_I2C_CTL, &val);
+	dev_info(&rdev->dev, "WF S_I2C_CTL staged disable S_I2C_CTL=0x%02x\n",
+		 val);
+
+	return ret;
+}
