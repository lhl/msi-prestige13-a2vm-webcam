+static const char *tps68470_regulator_reg_name(unsigned int reg)
+{
+	switch (reg) {
+	case TPS68470_REG_S_I2C_CTL:
+		return "S_I2C_CTL";
+	case TPS68470_REG_VACTL:
+		return "VACTL";
+	case TPS68470_REG_VDCTL:
+		return "VDCTL";
+	default:
+		return "UNKNOWN";
+	}
+}
+
+static int tps68470_regulator_update_bits_focus(struct regulator_dev *rdev,
+						unsigned int reg,
+						unsigned int mask,
+						unsigned int value,
+						const char *tag)
+{
+	unsigned int before = 0;
+	unsigned int after = 0;
+	int before_ret;
+	int ret;
+	int after_ret;
+
+	before_ret = regmap_read(rdev->regmap, reg, &before);
+	ret = regmap_update_bits(rdev->regmap, reg, mask, value);
+	after_ret = regmap_read(rdev->regmap, reg, &after);
+
+	dev_info(&rdev->dev,
+		 "pmic_focus: %s %s reg=%s(0x%02x) mask=0x%02x value=0x%02x before_ret=%d before=0x%02x update_ret=%d after_ret=%d after=0x%02x\n",
+		 tag, rdev->desc->name,
+		 tps68470_regulator_reg_name(reg), reg, mask, value,
+		 before_ret, before, ret, after_ret, after);
+
+	return ret;
+}
+
+static int tps68470_regulator_enable_vsio_split_trace(struct regulator_dev *rdev)
+{
+	unsigned int before = 0;
+	unsigned int after_bit1 = 0;
+	unsigned int after_bit0 = 0;
+	int before_ret;
+	int ret_bit1;
+	int after_bit1_ret;
+	int ret_bit0;
+	int after_bit0_ret;
+
+	before_ret = regmap_read(rdev->regmap, TPS68470_REG_S_I2C_CTL, &before);
+	ret_bit1 = regmap_update_bits(rdev->regmap, TPS68470_REG_S_I2C_CTL,
+				      BIT(1), BIT(1));
+	after_bit1_ret = regmap_read(rdev->regmap, TPS68470_REG_S_I2C_CTL,
+				     &after_bit1);
+
+	dev_info(&rdev->dev,
+		 "pmic_split: enable %s step=bit1 reg=S_I2C_CTL(0x43) mask=0x02 value=0x02 before_ret=%d before=0x%02x update_ret=%d after_ret=%d after=0x%02x\n",
+		 rdev->desc->name, before_ret, before, ret_bit1, after_bit1_ret,
+		 after_bit1);
+
+	if (ret_bit1 || after_bit1_ret)
+		return ret_bit1 ? ret_bit1 : after_bit1_ret;
+
+	ret_bit0 = regmap_update_bits(rdev->regmap, TPS68470_REG_S_I2C_CTL,
+				      BIT(0), BIT(0));
+	after_bit0_ret = regmap_read(rdev->regmap, TPS68470_REG_S_I2C_CTL,
+				     &after_bit0);
+
+	dev_info(&rdev->dev,
+		 "pmic_split: enable %s step=bit0 reg=S_I2C_CTL(0x43) mask=0x01 value=0x01 before_ret=%d before=0x%02x update_ret=%d after_ret=%d after=0x%02x\n",
+		 rdev->desc->name, after_bit1_ret, after_bit1, ret_bit0,
+		 after_bit0_ret, after_bit0);
+
+	if (ret_bit0)
+		return ret_bit0;
+
+	return after_bit0_ret;
+}
+
 static int tps68470_regulator_enable(struct regulator_dev *rdev)
 {
 	struct tps68470_regulator_data *data = rdev->reg_data;
+	unsigned int value;
 	int ret;
 
 	/* The Core buck regulator needs the PMIC's PLL to be enabled */
@@ -68,16 +150,51 @@
 		}
 	}
 
+	if (rdev->desc->id == TPS68470_ANA ||
+	    rdev->desc->id == TPS68470_CORE) {
+		if (rdev->desc->enable_is_inverted) {
+			value = rdev->desc->disable_val;
+		} else {
+			value = rdev->desc->enable_val;
+			if (!value)
+				value = rdev->desc->enable_mask;
+		}
+
+		return tps68470_regulator_update_bits_focus(rdev,
+							    rdev->desc->enable_reg,
+							    rdev->desc->enable_mask,
+							    value, "enable");
+	}
+
+	if (rdev->desc->id == TPS68470_VSIO)
+		return tps68470_regulator_enable_vsio_split_trace(rdev);
+
 	return regulator_enable_regmap(rdev);
 }
 
 static int tps68470_regulator_disable(struct regulator_dev *rdev)
 {
 	struct tps68470_regulator_data *data = rdev->reg_data;
+	unsigned int value;
 
 	if (rdev->desc->id == TPS68470_CORE)
 		clk_disable_unprepare(data->clk);
 
+	if (rdev->desc->id == TPS68470_VSIO) {
+		if (rdev->desc->enable_is_inverted) {
+			value = rdev->desc->enable_val;
+			if (!value)
+				value = rdev->desc->enable_mask;
+		} else {
+			value = rdev->desc->disable_val;
+		}
+
+		return tps68470_regulator_update_bits_focus(rdev,
+							    rdev->desc->enable_reg,
+							    rdev->desc->enable_mask,
+							    value, "disable");
+	}
+
 	return regulator_disable_regmap(rdev);
 }
 
