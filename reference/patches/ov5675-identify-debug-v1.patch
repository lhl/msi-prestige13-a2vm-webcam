@@ -881,25 +913,54 @@
 static int ov5675_identify_module(struct ov5675 *ov5675)
 {
 	int ret;
-	u32 val;
+	u32 val = 0;
+	unsigned int attempt, attempts;
 
 	if (ov5675->identified)
 		return 0;
 
-	ret = ov5675_read_reg(ov5675, OV5675_REG_CHIP_ID,
-			      OV5675_REG_VALUE_24BIT, &val);
-	if (ret)
-		return ret;
+	attempts = max(1U, ov5675_identify_retry_count);
+
+	for (attempt = 0; attempt < attempts; attempt++) {
+		ret = ov5675_read_reg(ov5675, OV5675_REG_CHIP_ID,
+				      OV5675_REG_VALUE_24BIT, &val);
+		if (!ret && val == OV5675_CHIP_ID) {
+			if (attempt)
+				dev_info(ov5675->dev,
+					 "sensor identified on attempt %u/%u\n",
+					 attempt + 1, attempts);
+			ov5675->identified = true;
+			return 0;
+		}
+
+		if (ret) {
+			dev_warn(ov5675->dev,
+				 "chip id read attempt %u/%u failed: %d\n",
+				 attempt + 1, attempts, ret);
+		} else {
+			dev_warn(ov5675->dev,
+				 "chip id attempt %u/%u mismatch: expected 0x%x got 0x%x\n",
+				 attempt + 1, attempts, OV5675_CHIP_ID, val);
+			ret = -ENXIO;
+		}
 
