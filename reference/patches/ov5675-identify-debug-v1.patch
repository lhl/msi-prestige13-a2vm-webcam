-			OV5675_CHIP_ID, val);
-		return -ENXIO;
+		if (attempt + 1 < attempts && ov5675_identify_retry_delay_us)
+			usleep_range(ov5675_identify_retry_delay_us,
+				     ov5675_identify_retry_delay_us + 100);
 	}
 
-	ov5675->identified = true;
+	return ret;
+}
 
