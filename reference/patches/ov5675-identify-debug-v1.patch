+/*
+ * Diagnostic tuning knobs for the current MSI bring-up path.
+ *
+ * Keep defaults close to stock behavior, but allow module-only iteration on
+ * identify timing and retries without another source edit.
+ */
+static unsigned int ov5675_identify_retry_count = 1;
+module_param_named(identify_retry_count, ov5675_identify_retry_count, uint, 0644);
+MODULE_PARM_DESC(identify_retry_count, "Number of OV5675 chip-ID read attempts");
+
+static unsigned int ov5675_identify_retry_delay_us = 2000;
+module_param_named(identify_retry_delay_us, ov5675_identify_retry_delay_us, uint, 0644);
+MODULE_PARM_DESC(identify_retry_delay_us, "Delay between OV5675 chip-ID read attempts in microseconds");
+
+static unsigned int ov5675_extra_post_power_on_delay_us;
+module_param_named(extra_post_power_on_delay_us, ov5675_extra_post_power_on_delay_us, uint, 0644);
+MODULE_PARM_DESC(extra_post_power_on_delay_us, "Extra delay after ov5675 reset deassert before chip-ID read, in microseconds");
+
 enum {
 	OV5675_LINK_FREQ_900MBPS,
 };
