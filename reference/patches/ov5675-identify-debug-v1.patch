+	dev_info(ov5675->dev, "applying extra post-power-on delay: %u us\n",
+		 ov5675_extra_post_power_on_delay_us);
+	usleep_range(ov5675_extra_post_power_on_delay_us,
+		     ov5675_extra_post_power_on_delay_us + 100);
 }
 
